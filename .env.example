# Access token for API authentication
# Generate a new UUID: uuidgen | tr '[:upper:]' '[:lower:]'
ACCESS_TOKEN=your-uuid-here

# Plex server configuration
# Example: http://192.168.1.10:32400
PLEX_BASE_URL=http://your-plex-host:32400
# Plex token from your server/account
PLEX_TOKEN=your-plex-token

# Optional: Server configuration
# HOST=0.0.0.0
# PORT=3000
